#!/usr/bin/env bash
# aztf -- thin wrapper that starts azemu (via docker-compose) if needed,
# exports the env vars the azurerm provider expects, and hands off to
# terraform. Phase 9 replaces this with a Go binary.
#
# Usage:
#   ./scripts/aztf init
#   ./scripts/aztf apply -auto-approve
#   ./scripts/aztf destroy -auto-approve

set -euo pipefail

# Resolve the repository root relative to this script's location.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Start azemu via docker-compose if it is not already running.
if ! docker compose -f "${REPO_ROOT}/docker-compose.yml" ps --status running 2>/dev/null | grep -q azemu; then
  echo "aztf: starting azemu via docker compose..." >&2
  docker compose -f "${REPO_ROOT}/docker-compose.yml" up -d --build
  # Wait for the health endpoint to come up.
  for i in $(seq 1 30); do
    if wget -qO- "http://localhost:4568/health" >/dev/null 2>&1; then
      break
    fi
    if [ "$i" -eq 30 ]; then
      echo "aztf: error: azemu did not become healthy within 30 seconds" >&2
      exit 1
    fi
    sleep 1
  done
fi

# Export the self-signed cert bundle so Go's TLS stack trusts azemu.
export SSL_CERT_FILE="${REPO_ROOT}/.azemu/cert-bundle.pem"

# Export mock credentials the azurerm provider needs.
export ARM_METADATA_HOSTNAME="127.0.0.1:4567"
export ARM_SUBSCRIPTION_ID="00000000-0000-0000-0000-000000000000"
export ARM_TENANT_ID="00000000-0000-0000-0000-000000000001"
export ARM_CLIENT_ID="00000000-0000-0000-0000-000000000002"
export ARM_CLIENT_SECRET="azemu-mock-secret"

exec terraform "$@"
