# Binary output. The bare `azemu` pattern that used to live here was a
# bug — it matched the cmd/azemu/ source directory and silently kept
# main.go untracked for the entire project history. The build artefact
# itself is at bin/azemu, which is already covered above.
bin/
*.exe

# goreleaser output
dist/
# But keep the embedded console SPA assets
!internal/console/dist/

# Terraform
.terraform/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl

# Go
coverage.out
coverage.html
*.coverprofile
*.test
vendor/

# OS
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.idea/
.vscode/
*.iml

# Docker
.docker/

# Temp files
/tmp/
*.tmp

# State persistence files (user-generated, not committed)
state.json
*.state.json

# Local TLS cert bundle written by AZEMU_CERT_PATH (contains private key)
.azemu/

# Public key the ota-delivery e2e exports from terraform for signature
# verification; regenerated each run and torn down by e2e.sh.
examples/terraform/scenarios/ota-delivery/pub.pem

# Per-project Claude Code tooling cache — personal state stays local, but
# .claude/rules/, .claude/agents/, and .claude/skills/ are project-shared
# content per https://code.claude.com/docs/en/memory (path-scoped rules),
# https://code.claude.com/docs/en/sub-agents (subagent role definitions),
# and https://code.claude.com/docs/en/skills (slash-invokable playbooks).
# The `.claude/*` glob only matches direct children of .claude/, so the
# negations below let those directories through while still ignoring
# .claude/settings.local.json and any other per-developer state.
.claude/*
!.claude/rules/
!.claude/agents/
!.claude/skills/

# MkDocs build output
website/site/

# Stray binary if `go build ./examples/...` is run from the repo root
/fixturegen
